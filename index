        '<div class="pgbar" style="width:260px"><div class="pgfill" id="examProg" style="width:0%"></div></div>'+
        '<small style="color:var(--muted);font-size:.79rem" id="answLbl2">0 de 15 respondidas</small>'+
      '</div>'+
      '<div style="display:flex;gap:10px;flex-wrap:wrap">'+
        '<button class="btn am" onclick="gradeExam()">📝 Calificar prueba</button>'+
        '<button class="btn rs" onclick="closeExam()">✕ Cerrar</button>'+
      '</div>'+
    '</div>'+
    '<div id="examResultArea" style="padding:0 28px 28px"></div>';
  overlay.classList.add('show');
  // Activate exam mode: hide all other page content
  document.body.classList.add('exam-active');
  overlay.classList.add('exam-mode');
}
function buildStudentForm(){
  var grupos='';
  for(var g=1;g<=6;g++)grupos+='<option value="'+g+'">Grupo '+g+'</option>';
  return'<div class="stu-form">'+
    '<h3>📋 Datos del estudiante / pareja</h3>'+
    '<p style="color:var(--muted);font-size:.88rem;margin-bottom:14px">Prueba individual o en pareja (opcional). Si es en pareja, completa los dos campos.</p>'+
    '<div class="form-grid">'+
      '<div><label class="lbl">Estudiante 1 — Apellidos y Nombres</label>'+
        '<input class="inp" id="stu1" type="text" placeholder="Ej: GARCÍA LÓPEZ, JUAN DAVID" style="text-transform:uppercase" oninput="this.value=this.value.toUpperCase()"></div>'+
      '<div><label class="lbl">Estudiante 2 — Apellidos y Nombres (opcional)</label>'+
        '<input class="inp" id="stu2" type="text" placeholder="Dejar en blanco si es individual" style="text-transform:uppercase" oninput="this.value=this.value.toUpperCase()"></div>'+
    '</div>'+
    '<div style="max-width:260px;margin-bottom:20px"><label class="lbl">Grupo</label>'+
    '<select class="inp" id="stuGrupo"><option value="">— Selecciona tu grupo —</option>'+grupos+'</select></div>'+
    '<div id="stuFormError" style="color:var(--rose);font-size:.88rem;margin-bottom:10px;display:none">⚠ Debes ingresar el nombre del Estudiante 1 y seleccionar el grupo.</div>'+
    '<button class="btn am" style="font-size:1rem;padding:13px 32px" onclick="startExam()">▶ Iniciar prueba</button>'+
  '</div>';
}
function closeExam(){
  if(_examActive&&!_examGraded){
    showWarnModal();
    return;
  }
  _examActive=false;
  removeExamGuards();
  document.getElementById('testOverlay').classList.remove('show','exam-mode');
  document.body.classList.remove('exam-active');
  clearInterval(_examTimerInt);
}
function updateAnswCount(){
  var n=0;
  for(var i=1;i<=15;i++){if(document.querySelector('input[name="eq'+i+'"]:checked'))n++;}
  var c=document.getElementById('answCountDisp');if(c)c.textContent=n+'/15 respondidas';
  var l=document.getElementById('answLbl2');if(l)l.textContent=n+' de 15 respondidas';
  var p=document.getElementById('examProg');if(p)p.style.width=(n/15*100)+'%';
}
function startExam(){
  // Validate form
  var s1=(document.getElementById('stu1')||{}).value||'';
  var gr=(document.getElementById('stuGrupo')||{}).value||'';
  var errEl=document.getElementById('stuFormError');
  if(!s1.trim()||!gr){
    if(errEl)errEl.style.display='block';
    return;
  }
  if(errEl)errEl.style.display='none';
  // Show questions and footer, hide form start button
  var qa=document.getElementById('questionsArea');
  var ft=document.getElementById('testFooter');
  var mb=document.getElementById('testMetaBar');
  var sf=document.querySelector('.stu-form button');
  var sfErr=document.getElementById('stuFormError');
  if(qa)qa.style.display='block';
  if(ft)ft.style.display='flex';
  if(mb)mb.style.display='flex';
  if(sf)sf.style.display='none';
  if(sfErr)sfErr.style.display='none';
  // Make form fields read-only
  var stu1el=document.getElementById('stu1');
  var stu2el=document.getElementById('stu2');
  var grupoEl=document.getElementById('stuGrupo');
  if(stu1el)stu1el.setAttribute('readonly','true');
  if(stu2el)stu2el.setAttribute('readonly','true');
  if(grupoEl)grupoEl.setAttribute('disabled','true');
  // Scroll to questions
  if(qa)qa.scrollIntoView({behavior:'smooth',block:'start'});
  // Start 40-minute timer immediately
  clearInterval(_examTimerInt);
  _examTimeLeft=2400;
  _examTimerInt=setInterval(function(){
    _examTimeLeft--;
    var m=String(Math.floor(_examTimeLeft/60)).padStart(2,'0');
    var s=String(_examTimeLeft%60).padStart(2,'0');
    var el=document.getElementById('timerDisp');
    if(el){el.textContent=m+':'+s;el.style.color=_examTimeLeft<300?'#ff4444':'';}
    if(_examTimeLeft<=0){clearInterval(_examTimerInt);gradeExam();}
  },1000);
  // Lock navigation
  addExamGuards();
}
function startExamTimer(){startExam();}
function gradeExam(reason){
  if(_examGraded)return;
  _examGraded=true;
  _examActive=false;
  clearInterval(_examTimerInt);
  // Disable all radio buttons to freeze answers
  document.querySelectorAll('input[type="radio"][name^="eq"]').forEach(function(r){r.disabled=true;});
  var ex=EXAMS[_currentVer];
  var stu1=(document.getElementById('stu1')||{}).value||'Sin nombre';
  var stu2=(document.getElementById('stu2')||{}).value||'';
  var grupo=(document.getElementById('stuGrupo')||{}).value||'—';
  var score=0;
  var compRes={};
  ex.qs.forEach(function(q){
    var sel=document.querySelector('input[name="eq'+q.n+'"]:checked');
    var ok=sel&&sel.value===q.ans;
    if(ok)score++;
    if(!compRes[q.c])compRes[q.c]={ok:0,total:0};
    compRes[q.c].total++;
    if(ok)compRes[q.c].ok++;
    document.querySelectorAll('input[name="eq'+q.n+'"]').forEach(function(r){
      var lb=r.closest('label');
      if(lb){
        if(r.value===q.ans)lb.classList.add('res-hi-ok');
        else if(r.checked)lb.classList.add('res-hi-no');
      }
    });
    var qel=document.getElementById('eq'+q.n);
    if(qel&&!qel.querySelector('.exp-note')){
      var d=document.createElement('div');
      d.className='exp-note';
      d.innerHTML='<strong>💡 Explicación: </strong>'+q.exp;
      qel.appendChild(d);
    }
  });
  var pct=Math.round(score/15*100);
  var level=score>=13?'Superior':score>=11?'Alto':score>=8?'Básico':score>=5?'Bajo':'Mínimo';
  var color=score>=11?'var(--teal)':score>=8?'var(--amber)':'var(--rose)';
  var motivo=reason||'Entrega voluntaria';
  var res={
    fecha:new Date().toLocaleString('es-CO'),
    estudiante1:stu1.trim()||'Sin nombre',
    estudiante2:stu2.trim()||'—',
    grupo:grupo||'—',
    version:_currentVer,
    puntaje:score,
    porcentaje:pct,
    nivel:level,
    motivo:motivo,
    interpretacion:compRes['Interpretación']?compRes['Interpretación'].ok:0,
    formulacion:compRes['Formulación']?compRes['Formulación'].ok:0,
    razonamiento:compRes['Razonamiento']?compRes['Razonamiento'].ok:0
  };
  examResults.push(res);
  try{localStorage.setItem('examResults',JSON.stringify(examResults));}catch(e){}
  // Send to Google Sheets
  sendToSheets(res);
  // Remove exam-active mode
  document.body.classList.remove('exam-active');
  removeExamGuards();
  var area=document.getElementById('examResultArea');
  if(area){
    var exitMsg=reason&&reason!=='Entrega voluntaria'?'<div style="background:#fff3cd;border:1px solid #e0a800;border-radius:4px;padding:10px 16px;margin-bottom:14px;font-size:.9rem;color:#664d03">⚠️ Prueba finalizada automáticamente: '+reason+'</div>':'';
    area.innerHTML=
      exitMsg+
      '<div style="background:'+color+';color:white;border-radius:4px;padding:24px 28px;margin-top:8px">'+
        '<div style="font-family:\'Playfair Display\',serif;font-size:2.5rem;font-weight:900">'+score+'/15 <span style="font-size:1.2rem;opacity:.8">('+pct+'%)</span></div>'+
        '<div style="font-size:1rem;margin:6px 0 16px;opacity:.85">Nivel: <strong>'+level+'</strong> | '+res.estudiante1+(res.estudiante2&&res.estudiante2!='—'?' · '+res.estudiante2:'')+' | Grupo '+grupo+'</div>'+
        '<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px">'+
          Object.keys(compRes).map(function(k){
            return'<div style="background:rgba(255,255,255,.15);border-radius:4px;padding:12px;text-align:center">'+
              '<div style="font-size:1.3rem;font-weight:700">'+compRes[k].ok+'/'+compRes[k].total+'</div>'+
              '<div style="font-size:.78rem;opacity:.8">'+k+'</div></div>';
          }).join('')+
        '</div>'+
        '<div id="sheetsSendStatus" style="margin-top:14px;font-size:.85rem;opacity:.8">'+
          '<span class="send-spinner"></span>Enviando resultados a Google Sheets...'+
        '</div>'+
      '</div>';
    area.scrollIntoView({behavior:'smooth'});
  }
}

// ═══════════════════════════════════════════
// GOOGLE SHEETS INTEGRATION
// ═══════════════════════════════════════════
// INSTRUCCIONES PARA EL DOCENTE:
// 1. Abre Google Sheets y crea una hoja nueva.
// 2. Ve a Extensiones → Apps Script y pega el script del archivo adjunto.
// 3. Despliega como aplicación web (Ejecutar como: Yo; Acceso: Cualquier persona).
// 4. Copia la URL del despliegue y reemplaza el valor de SHEETS_URL abajo.
var SHEETS_URL='https://script.google.com/macros/s/AKfycbyo-OW-IjFWwTIuMUnEEGy5wLYRU7PxMvKdgO7xXBBQ9XBC-uj1_A8S7F5IHpt0MRXmNQ/exec';

function sendToSheets(res){
  var payload={
    fecha:res.fecha,
    estudiante1:res.estudiante1,
    estudiante2:res.estudiante2,
    grupo:res.grupo,
    version:res.version,
    puntaje:res.puntaje,
    porcentaje:res.porcentaje,
    nivel:res.nivel,
    motivo:res.motivo||'Entrega voluntaria',
    interpretacion:res.interpretacion,
    formulacion:res.formulacion,
    razonamiento:res.razonamiento
  };
  // Use no-cors fetch so it works from any device without CORS issues
  fetch(SHEETS_URL,{
    method:'POST',
    mode:'no-cors',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify(payload)
  }).then(function(){
    var el=document.getElementById('sheetsSendStatus');
    if(el)el.innerHTML='✅ Resultado registrado en Google Sheets';
  }).catch(function(err){
    var el=document.getElementById('sheetsSendStatus');
    if(el)el.innerHTML='⚠️ No se pudo enviar a Sheets (revisa la URL). Guardado localmente.';
    console.warn('Sheets error:',err);
  });
}

// ═══════════════════════════════════════════
// EXAM GUARDS — block navigation during exam
// ═══════════════════════════════════════════
var _examActive=false;
var _examGraded=false;
var _pendingExit=false;

function addExamGuards(){
  _examActive=true;
  _examGraded=false;
  _pendingExit=false;
  // Block browser back / forward
  history.pushState(null,'',location.href);
  window.addEventListener('popstate',_onPopState);
  // Block tab close / refresh
  window.addEventListener('beforeunload',_onBeforeUnload);
  // Detect visibility change (minimize / switch tab)
  document.addEventListener('visibilitychange',_onVisibility);
}
function removeExamGuards(){
  _examActive=false;
  window.removeEventListener('popstate',_onPopState);
  window.removeEventListener('beforeunload',_onBeforeUnload);
  document.removeEventListener('visibilitychange',_onVisibility);
}
function _onPopState(){
  if(!_examActive)return;
  history.pushState(null,'',location.href); // block going back
  showWarnModal();
}
function _onBeforeUnload(e){
  if(!_examActive)return;
  e.preventDefault();
  e.returnValue='';
  return'';
}
function _onVisibility(){
  if(!_examActive||document.visibilityState!=='hidden')return;
  // Page was hidden (minimized, tab switched)
  showWarnModal();
}
function showWarnModal(){
  if(_pendingExit||_examGraded)return;
  _pendingExit=true;
  document.getElementById('warnModal').classList.add('show');
}
function cancelExit(){
  _pendingExit=false;
  document.getElementById('warnModal').classList.remove('show');
}
function confirmExit(){
  document.getElementById('warnModal').classList.remove('show');
  // Show finalization message in the exam area then grade
  var area=document.getElementById('examResultArea');
  if(area){
    area.innerHTML='<div style="background:var(--rose);color:white;border-radius:4px;padding:18px 24px;margin-top:8px;font-size:1rem">'+
      '<strong>Prueba finalizada.</strong> Se registrarán los resultados de las preguntas contestadas hasta este momento.'+
    '</div>';
    area.scrollIntoView({behavior:'smooth'});
  }
  setTimeout(function(){gradeExam('Salida / minimización de página');},800);
}

// ═══════════════════════════════════════════
// TEACHER PANEL
// ═══════════════════════════════════════════
var _teacherPass='RG9jZW50ZTIwMjUq';
function _getTP(){return atob(_teacherPass);}

function openTeacherModal(e){
  if(e)e.preventDefault();
  document.getElementById('taIn').value='';
  document.getElementById('taErr').style.display='none';
  document.getElementById('taModal').classList.add('show');
  setTimeout(function(){document.getElementById('taIn').focus();},100);
}
function verifyTeacher(){
  var v=document.getElementById('taIn').value;
  if(v===_getTP()){
    document.getElementById('taModal').classList.remove('show');
    buildPanel();
    document.getElementById('teacherPanel').classList.add('show');
    window.scrollTo(0,0);
  }else{
    document.getElementById('taErr').style.display='block';
    document.getElementById('taIn').value='';
  }
}
function closePanel(){document.getElementById('teacherPanel').classList.remove('show');}

function buildPanel(){
  var r=examResults;
  var statsEl=document.getElementById('panelStats');
  var tableEl=document.getElementById('panelTableWrap');
  if(!r.length){
    statsEl.innerHTML='<p style="opacity:.6;grid-column:1/-1;color:var(--cream)">No hay resultados registrados aún.</p>';
    tableEl.innerHTML='';return;
  }
  var totalPts=r.reduce(function(a,x){return a+x.puntaje;},0);
  var avPts=totalPts/r.length;
  var byGroup={};
  r.forEach(function(x){if(!byGroup[x.grupo])byGroup[x.grupo]=[];byGroup[x.grupo].push(x.puntaje);});
  statsEl.innerHTML=
    '<div class="stat-box"><div class="val">'+r.length+'</div><div class="lbl2">Pruebas realizadas</div></div>'+
    '<div class="stat-box"><div class="val">'+avPts.toFixed(1)+'/15</div><div class="lbl2">Puntaje promedio</div></div>'+
    '<div class="stat-box"><div class="val">'+Math.round(avPts/15*100)+'%</div><div class="lbl2">% promedio</div></div>'+
    '<div class="stat-box"><div class="val">'+Math.max.apply(null,r.map(function(x){return x.puntaje;}))+'/15</div><div class="lbl2">Puntaje máximo</div></div>'+
    '<div class="stat-box"><div class="val">'+Math.min.apply(null,r.map(function(x){return x.puntaje;}))+'/15</div><div class="lbl2">Puntaje mínimo</div></div>'+
    '<div class="stat-box"><div class="val">'+Object.keys(byGroup).length+'</div><div class="lbl2">Grupos participantes</div></div>';
  var rows=r.map(function(x){
    return'<tr><td style="font-size:.76rem">'+x.fecha+'</td><td>'+x.estudiante1+'</td><td>'+x.estudiante2+'</td>'+
      '<td>Grupo '+x.grupo+'</td><td>V'+x.version+'</td>'+
      '<td style="font-weight:700;color:var(--amber-l)">'+x.puntaje+'/15</td>'+
      '<td>'+x.porcentaje+'%</td><td>'+x.nivel+'</td>'+
      '<td>'+(x.motivo||'—')+'</td>'+
      '<td>'+x.interpretacion+'/5</td><td>'+x.formulacion+'/5</td><td>'+x.razonamiento+'/5</td></tr>';
  }).join('');
  tableEl.innerHTML=
    '<h3 style="font-family:\'Playfair Display\',serif;color:var(--amber-l);margin-bottom:14px">Detalle de resultados</h3>'+
    '<div style="overflow-x:auto"><table>'+
    '<thead><tr><th>Fecha</th><th>Estudiante 1</th><th>Estudiante 2</th><th>Grupo</th><th>Ver.</th><th>Puntaje</th><th>%</th><th>Nivel</th><th>Motivo</th><th>Interp.</th><th>Formul.</th><th>Razon.</th></tr></thead>'+
    '<tbody>'+rows+'</tbody></table></div>';
}
function clearResults(){
  if(confirm('¿Seguro que deseas borrar todos los resultados?')){
    examResults=[];
    try{localStorage.removeItem('examResults');}catch(e){}
    buildPanel();
  }
}
function exportExcel(){
  if(!examResults.length){alert('No hay resultados para exportar.');return;}
  var data=[
    ['RESULTADOS — PRUEBA DE ESTADÍSTICA GRADO 11°'],
    [],
    ['Fecha','Estudiante 1','Estudiante 2','Grupo','Versión','Puntaje','Porcentaje','Nivel','Motivo','Interpretación /5','Formulación /5','Razonamiento /5']
  ];
  examResults.forEach(function(r){
    data.push([r.fecha,r.estudiante1,r.estudiante2,r.grupo,'Versión '+r.version,r.puntaje,r.porcentaje+'%',r.nivel,r.motivo||'—',r.interpretacion,r.formulacion,r.razonamiento]);
  });
  var avgP=(examResults.reduce(function(a,x){return a+x.puntaje;},0)/examResults.length).toFixed(2);
  data.push([]);
  data.push(['RESUMEN']);
  data.push(['Total pruebas',examResults.length]);
  data.push(['Puntaje promedio',avgP+'/15']);
  data.push(['% promedio',Math.round(avgP/15*100)+'%']);
  data.push(['Máximo',Math.max.apply(null,examResults.map(function(x){return x.puntaje;}))+'/15']);
  data.push(['Mínimo',Math.min.apply(null,examResults.map(function(x){return x.puntaje;}))+'/15']);
  var wb=XLSX.utils.book_new();
  var ws=XLSX.utils.aoa_to_sheet(data);
  ws['!cols']=[{wch:22},{wch:30},{wch:30},{wch:10},{wch:10},{wch:10},{wch:12},{wch:12},{wch:20},{wch:16},{wch:14},{wch:14}];
  XLSX.utils.book_append_sheet(wb,ws,'Resultados');
  XLSX.writeFile(wb,'Resultados_Estadistica_11_'+new Date().toLocaleDateString('es-CO').replace(/\//g,'-')+'.xlsx');
}
