// Build 5 exams by shuffling all questions and taking 15 (5 per competency)
function buildExamVersions(){
  var interp=ALL_QUESTIONS.filter(function(q){return q.c==='Interpretación';});
  var form=ALL_QUESTIONS.filter(function(q){return q.c==='Formulación';});
  var razon=ALL_QUESTIONS.filter(function(q){return q.c==='Razonamiento';});
  var versions={};
  for(var v=1;v<=5;v++){
    // Shuffle each group with a version-specific seed (simple deterministic shuffle)
    var si2=shuffle(interp,v*7);
    var sf=shuffle(form,v*13);
    var sr=shuffle(razon,v*19);
    var qs=[];
    for(var i=0;i<5;i++){qs.push(Object.assign({n:i+1},si2[i]||interp[i%interp.length]));}
    for(var j=0;j<5;j++){qs.push(Object.assign({n:6+j},sf[j]||form[j%form.length]));}
    for(var k=0;k<5;k++){qs.push(Object.assign({n:11+k},sr[k]||razon[k%razon.length]));}
    // Renumber and shuffle order within exam
    var exam=shuffle(qs,v*31);
    exam.forEach(function(q,idx){q.n=idx+1;});
    versions[v]={title:'Prueba de Estadística — Grado 11°',qs:exam};
  }
  return versions;
}
function shuffle(arr,seed){
  var a=arr.slice();
  var s=seed||1;
  for(var i=a.length-1;i>0;i--){
    s=(s*9301+49297)%233280;
    var j=Math.floor((s/233280)*(i+1));
    var tmp=a[i];a[i]=a[j];a[j]=tmp;
  }
  return a;
}
