    var med=(n%2===0?(d[n/2-1]+d[n/2])/2:d[Math.floor(n/2)]);
    _A3ans=med.toFixed(0);
    return'Ingresos mensuales de 9 familias (miles $): <em>'+d.join(', ')+'</em>.<br>Calcula la <strong>mediana</strong>.<br><input id="ai3" class="inp" style="width:130px;margin-top:10px" placeholder="Número">';
  },
  function(){
    var vals=[2,3,4,5];
    var mo=vals[rnd(0,3)];
    var base=ra(5,2,5);
    var full=base.concat([mo,mo,mo]).sort(function(a,b){return a-b;});
