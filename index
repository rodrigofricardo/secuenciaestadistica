var _sciState={};
function buildSci(id){
  var el=document.getElementById(id);
  if(!el||el.innerHTML.trim())return;
  var btns=[
    ['sin(','cos(','tan(','log(','ln(','√('],
    ['π','e','(',')','^','!'],
    ['7','8','9','÷','C','←'],
    ['4','5','6','×','%','±'],
    ['1','2','3','-',' ',' '],
    ['0','.',' ','+',' ','=']
  ];
  var html='<div class="sdisp"><div class="sexp" id="'+id+'_e"></div><div class="sval" id="'+id+'_v">0</div></div><div class="sbg">';
  btns.forEach(function(row){
    row.forEach(function(b){
      if(b===' '){html+='<span></span>';return;}
      var cls='';
      if(['sin(','cos(','tan(','log(','ln(','√(','π','e','!'].indexOf(b)>=0)cls='fn';
      else if(['÷','×','-','+','^','%'].indexOf(b)>=0)cls='op';
      else if(b==='=')cls='eq';
      else if(b==='C')cls='cl';
      html+='<button class="sb '+cls+'" onclick="si(\''+id+'\',\''+b+'\')">'+b+'</button>';
    });
  });
  html+='</div>';
  el.innerHTML=html;
  _sciState[id]={e:'',v:'0'};
}
function si(id,btn){
  buildSci(id);
  var st=_sciState[id];
  if(!st)return;
  var e=st.e;
  if(btn==='C'){e='';st.v='0';}
  else if(btn==='←'){e=e.slice(0,-1);}
  else if(btn==='='){
    try{
      var x=e.replace(/÷/g,'/').replace(/×/g,'*')
        .replace(/π/g,'Math.PI').replace(/e(?![0-9])/g,'Math.E')
        .replace(/sin\(/g,'Math.sin(').replace(/cos\(/g,'Math.cos(')
        .replace(/tan\(/g,'Math.tan(').replace(/log\(/g,'Math.log10(')
        .replace(/ln\(/g,'Math.log(').replace(/√\(/g,'Math.sqrt(')
        .replace(/\^/g,'**').replace(/(\d+)!/g,'_f($1)');
      var r=Function('"use strict";function _f(n){return n<=1?1:n*_f(n-1);}return '+x)();
      st.v=(+r.toFixed(10))+'';
      var ep=document.getElementById(id+'_e');
      if(ep)ep.textContent=e+' =';
      e='';
    }catch(err){st.v='Error';}
  }else if(btn==='±'){
    if(st.v!=='0'&&st.v!=='Error')st.v=(parseFloat(st.v)*-1)+'';
  }else{
    e+=btn;
  }
  st.e=e;
  var vp=document.getElementById(id+'_v');
  if(vp)vp.textContent=st.v||'0';
  if(e){var ep2=document.getElementById(id+'_e');if(ep2)ep2.textContent=e;}
}
function toggleCalc(id){
  buildSci(id);
  var el=document.getElementById(id);
  if(el)el.classList.toggle('open');
}

